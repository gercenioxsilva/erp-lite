{
  "name": "@erp-lite/api-core",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "ts-node --transpile-only src/scripts/migrate.ts",
    "seed": "node dist/scripts/seed.js",
    "seed:nfe": "ts-node --transpile-only src/scripts/seed-nfe.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^4.29.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/sensible": "^5.6.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.6.6",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.27.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}