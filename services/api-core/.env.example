# ─────────────────────────────────────────────────────────────────────────────
# api-core — variáveis de ambiente
#
# Copie para .env e ajuste. NADA aqui é segredo real: nunca comite um .env.
#
# LEIA ANTES: desde a migration 0087, as credenciais de INTEGRAÇÃO (SERPRO,
# Pluggy, Google Calendar) são configuradas POR TENANT na tela Integrações do
# backoffice, e ficam no banco. As variáveis correspondentes abaixo viraram
# FALLBACK DE PLATAFORMA: valem só para os tenants que ainda não configuraram a
# própria conta. Para dev/homologação, preencher aqui continua sendo o caminho
# mais rápido.
#
# Regra de gating em todo o sistema: variável ausente NÃO quebra nada. A rota
# responde 503 com corpo padronizado e a tela mostra "integração aguardando
# configuração" — nunca um erro vermelho ou 500.
# ─────────────────────────────────────────────────────────────────────────────

# ── Obrigatórias ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://erp_lite:erp_lite@localhost:5432/erp_lite
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Assina os JWT de sessão. Troque por um valor longo e aleatório em produção.
JWT_SECRET=change-me-before-production

# URL pública do backoffice. Base dos redirects de OAuth (Google) e Stripe.
# Errar isto faz o usuário voltar do consentimento para o ambiente errado.
APP_URL=http://localhost:5173

# ── AWS (filas, buckets, e-mail) ─────────────────────────────────────────────
AWS_REGION=us-east-1
# Só em dev com LocalStack. Em produção NÃO defina (a task ECS usa IAM role).
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

NFE_REQUESTS_QUEUE_URL=http://localhost:4566/000000000000/nfe-requests
NFE_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/nfe-results
NFE_BUCKET=nfe-xmls-local
NOTIFICATIONS_QUEUE_URL=http://localhost:4566/000000000000/notifications
BILLING_REQUESTS_QUEUE_URL=http://localhost:4566/000000000000/billing-requests
BILLING_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/billing-results
BILLING_BUCKET=billing-pdfs-local
WHATSAPP_REQUESTS_QUEUE_URL=http://localhost:4566/000000000000/whatsapp-requests
WHATSAPP_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/whatsapp-results
MARKETPLACE_SYNC_REQUESTS_QUEUE_URL=http://localhost:4566/000000000000/marketplace-sync-requests
MARKETPLACE_SYNC_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/marketplace-sync-results
SERVICE_VISIT_PHOTOS_BUCKET=service-visit-photos-local

# Importação de documentos (OFX/CSV/XLSX). AUSENTE = import funciona normalmente,
# só não arquiva o arquivo original no S3.
FISCAL_IMPORTS_BUCKET=fiscal-imports-local
# PDF do DAS gerado via SERPRO. Ausente, cai em FISCAL_IMPORTS_BUCKET.
FISCAL_DOCS_BUCKET=fiscal-docs-local

# E-mail transacional (SES)
SES_FROM_EMAIL=noreply@localhost
SES_FROM_NAME=GAX ERP (local)

# ── Emissão de notas — Focus NF-e ────────────────────────────────────────────
# Token mestre da plataforma. Cada empresa pode ter o próprio token em
# nfe_configs; este é o fallback. Prefixo 'local-' liga o modo de SIMULAÇÃO
# (nenhuma chamada externa) — use em dev/E2E.
FOCUS_NFE_TOKEN=local-sandbox-token
# Default é homologação. Só aponte para produção quando for emitir de verdade.
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br

# ── PGDAS-D / DAS — SERPRO Integra Contador ──────────────────────────────────
# ⚠ Configurável por tenant na tela Integrações (o normal em produção: cada
# empresa contrata a própria na loja SERPRO). O que segue é o fallback.
#
# São 4 variáveis all-or-nothing: faltando uma, a integração fica inativa.
# O e-CNPJ do mTLS TEM de ser o mesmo CNPJ que contratou na loja SERPRO.
# ⚠ CUSTO: HTTP 403 é COBRADO pela SERPRO — permissão mal configurada gasta
# dinheiro a cada tentativa.
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
# Certificado e-CNPJ A1 (.pfx) em base64:  base64 -i certificado.pfx | tr -d '\n'
SERPRO_MTLS_PFX_BASE64=
SERPRO_MTLS_PFX_PASSWORD=
# 'trial' (default) ou 'producao'.
SERPRO_ENV=trial

# ── Open Finance / conciliação automática — Pluggy ───────────────────────────
# ⚠ Configurável por tenant na tela Integrações. Abaixo é o fallback.
# Prefixo 'local-' no CLIENT_ID liga a SIMULAÇÃO (banco sintético, sem rede).
# Não há webhook: o sync é por polling.
PLUGGY_CLIENT_ID=local-dev
PLUGGY_CLIENT_SECRET=local-secret
PLUGGY_BASE_URL=https://api.pluggy.ai

# ── Google Calendar (módulo Agendamento) ─────────────────────────────────────
# ⚠ Configurável por tenant na tela Integrações. Abaixo é o fallback.
# Credencial OAuth 2.0 tipo "Aplicativo Web" no Google Cloud Console.
# O escopo calendar.events é SENSÍVEL: publicar exige app verificado pelo
# Google (ou manter os usuários na lista de teste).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Precisa estar registrada IDÊNTICA no console do Google. Ausente, é derivada
# de APP_URL. Aponta para ESTA API, não para o backoffice.
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/public/integrations/google/callback
# Assina o `state` do OAuth. Ausente, cai em JWT_SECRET.
MARKETPLACE_STATE_SECRET=

# ── Assistente IA e conciliação semântica — Anthropic ────────────────────────
# Chave DA PLATAFORMA (não é por tenant: o custo é seu). Ausente ⇒ assistente
# fiscal responde 503 e a conciliação usa só o algoritmo determinístico local.
ANTHROPIC_API_KEY=
# Opcional. Default: claude-sonnet-5
ANTHROPIC_MODEL=
# Opcional. Teto de chamadas/dia por tenant (429 ao estourar).
ASSISTANT_DAILY_CAP=

# ── Cobrança bancária ────────────────────────────────────────────────────────
# Itaú é credencial de plataforma. C6 é POR TENANT (lida da mensagem SQS).
ITAU_CLIENT_ID=
ITAU_CLIENT_SECRET=
ITAU_BASE_URL=https://sandbox.devportal.itau.com.br
ITAU_AUTH_URL=https://sts.itau.com.br/itauBank/api/v2/token

# ── Marketplace (Mercado Livre) ──────────────────────────────────────────────
# Atenção: api-core lê MERCADOLIVRE_* (sem "_" entre MERCADO e LIVRE);
# o lambda-marketplace lê MERCADO_LIVRE_*. Não são a mesma variável.
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=

# ── Assinaturas (Stripe) ─────────────────────────────────────────────────────
# Modo teste em dev. Sem estas, o módulo de assinatura fica inativo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Diversos ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
# E-mail do dono do sistema (acesso de suporte).
SYSTEM_OWNER_EMAIL=
